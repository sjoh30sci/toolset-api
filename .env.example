# .env.example
# Copy to .env.local (gitignored) and adjust for your environment.

# Gateway
TOOLSET_AUTH_MODE=none          # none | token
TOOLSET_PORT=8080
TOOLSET_LOG_LEVEL=info          # debug | info | warn | error
TOOLSET_DB_PATH=/data/toolset.db

# Auth tokens (only used when TOOLSET_AUTH_MODE=token)
TOOLSET_TOKEN_SEARCH=sk_search_changeme
TOOLSET_TOKEN_EXEC=sk_exec_changeme
