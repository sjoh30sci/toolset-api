# config.yaml.example
# Copy to config.yaml (gitignored) to customize. Environment variables
# (TOOLSET_*) always override values defined here.

server:
  port: 8080
  fallback_port: 18080
  log_level: info  # debug | info | warn | error

auth:
  mode: none  # none | token
  # Only used when mode: token. Each entry maps a logical tool -> bearer token.
  api_tokens:
    search: "sk_search_xxx"
    exec: "sk_exec_xxx"
  # Default requests/minute per token or IP.
  rate_limit: 100

db:
  path: /data/toolset.db
  max_connections: 10

tools:
  search:
    enabled: true
    container: search
  files:
    enabled: true
    container: files-server
    sandbox_root: /data/files
  exec:
    enabled: true
    container: exec-light
  browser:
    enabled: true
    container: browser

# Phase 2 tool settings. These are consumed by the gateway when proxying.
search:
  enabled: true
  timeout: 5s            # per-request upstream timeout
  # Default engines used when a request omits "engines". Empty = all enabled.
  engines:
    - google
    - bing
    - duckduckgo
    - brave

files:
  enabled: true
  sandbox_root: /data/files
  max_file_size: 104857600   # 100MB, in bytes

# Phase 3 code-execution settings. Consumed by the gateway to route requests to
# the exec-light / exec-heavy sandbox containers and to size the async worker pool.
exec:
  light_enabled: true
  heavy_enabled: false  # Disable if you don't need .NET/Java/Rust
  default_timeout: 30
  max_timeout: 300
  queue_workers: 2
  languages:
    light: [python, node, bash, c, cpp, assembly]
    heavy: [dotnet, java, rust, csharp]
